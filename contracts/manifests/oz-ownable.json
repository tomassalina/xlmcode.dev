{
  "id": "oz-ownable",
  "name": "Ownable",
  "description": "OpenZeppelin single-owner access control. One account is authorized for all privileged actions; ownership is transferable in two steps.",
  "type": "deployable",
  "category": "access",
  "wasmPath": "contracts/wasm/ownable.wasm",
  "init": {
    "method": "__constructor",
    "argsFromConfig": ["owner"]
  },
  "config": [
    { "key": "owner", "label": "Owner", "type": "address", "default": "{{deployer}}" }
  ],
  "methods": [
    { "name": "get_owner", "args": [], "returns": "address", "mutates": false },
    { "name": "transfer_ownership", "args": ["new_owner", "live_until_ledger"], "returns": "void", "mutates": true },
    { "name": "accept_ownership", "args": [], "returns": "void", "mutates": true },
    { "name": "renounce_ownership", "args": [], "returns": "void", "mutates": true },
    { "name": "increment", "args": [], "returns": "i32", "mutates": true }
  ]
}
