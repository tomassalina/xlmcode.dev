{
  "name": "xlmcode",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "server": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "seed:templates": "tsx scripts/seed-templates.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b && tsc -p server/tsconfig.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.1",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "ai": "^7.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^7.18.0",
    "stellar-hd-wallet": "^1.0.2",
    "zod": "^4.4.3"
