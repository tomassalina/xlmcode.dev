# Copy to .env.local and fill in. NEVER commit real keys.
# .env.local is git-ignored.

# --- LLM (BYOK) ---
# In production each user brings their own key via the UI (never persisted).
# For local dev only, this acts as a fallback so you can test without the UI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# --- Stellar (testnet) ---
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Backend deployer account that pays for deploys. Generated + funded via script
# in Milestone 2 (do not fill this by hand).
STELLAR_DEPLOYER_SECRET=

# --- Supabase (Milestone 5) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
